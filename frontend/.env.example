# API Configuration
# The base URL for the backend API
# For development with Vite proxy: http://localhost:5209/api/v1
# For production: https://your-api-domain.com/api/v1
VITE_API_BASE_URL=http://localhost:5209/api/v1

# Vite Dev Server Configuration (for development only)
# Frontend dev server port
VITE_DEV_PORT=5209

# Backend API proxy target (for Vite dev server proxy)
VITE_API_PROXY_TARGET=http://localhost:5208

# Preview Server Configuration (for npm run start/preview)
# Port for previewing production build
VITE_PREVIEW_PORT=4173
