# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sync_accounting

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# App
DEBUG=True
APP_NAME=Sync Accounting Software

# QuickBooks Online API (Phase 2 - Optional)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:5209/auth/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# OCR Services (Optional)
TESSERACT_CMD=/usr/local/bin/tesseract
GOOGLE_CLOUD_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
